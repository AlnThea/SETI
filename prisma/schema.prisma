generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PublicationType {
  REPORT
  POLICY_BRIEF
  ARTICLE
  CASE_STUDY
  TOOLKIT
}

enum StakeholderType {
  policymaker
  industry
  researcher
  financial_institution
  media
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}

model Theme {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  description  String
  color        String
  publications Publication[]
  projects     Project[]
  policies     Policy[]
  events       Event[]
  experts      Expert[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String
  publications Publication[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Stakeholder {
  id           String          @id @default(cuid())
  name         String
  type         String          @unique
  description  String
  guidance     String
  publications Publication[]
  projects     Project[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Publication {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  summary          String
  type             PublicationType
  featured         Boolean         @default(false)
  publishedAt      DateTime?
  organizationName String
  themeId          String
  organizationId   String?
  theme            Theme           @relation(fields: [themeId], references: [id])
  organization     Organization?   @relation(fields: [organizationId], references: [id])
  stakeholders     Stakeholder[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Project {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  description    String
  province       String
  location       String
  status         ProjectStatus
  impactHeadline String
  startDate      DateTime
  endDate        DateTime?
  themeId        String
  theme          Theme         @relation(fields: [themeId], references: [id])
  stakeholders   Stakeholder[]
  impacts        Impact[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Impact {
  id          String   @id @default(cuid())
  metric      String
  value       Float
  unit        String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  measuredAt  DateTime
  createdAt   DateTime @default(now())
}

model Policy {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  publishedAt DateTime
  themeId     String
  theme       Theme    @relation(fields: [themeId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  eventDate   DateTime
  location    String
  themeId     String
  theme       Theme    @relation(fields: [themeId], references: [id])
}

model Expert {
  id          String   @id @default(cuid())
  name        String
  role        String
  organization String
  themeId     String
  theme       Theme    @relation(fields: [themeId], references: [id])
}

